# Wajib — koneksi Neon Postgres (harus support SSL)
POSTGRES_URL=

# Wajib — secret untuk session/login
# Mac/Linux: openssl rand -base64 32
# Windows (PowerShell): [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
# Windows (Node): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Opsional — untuk NextAuth callback lokal
AUTH_URL=http://localhost:3000/api/auth